# Declutr Production Environment Variables Template

APP_ENV=production
PORT=8080
LOG_LEVEL=INFO

# Database Settings
DATABASE_URL=postgres://declutr_user:strong_password@postgres-primary.internal:5432/declutr_prod?sslmode=require
DATABASE_MAX_CONNS=100
DATABASE_IDLE_CONNS=25

# Cache Settings
REDIS_URL=redis://redis-cluster.internal:6379

# Storage Provider Settings
STORAGE_PROVIDER=s3
STORAGE_BUCKET=declutr-production-vault
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AI Provider Settings
AI_PROVIDER=openai
OPENAI_API_KEY=sk-prod-your-openai-api-key

# Vector Database Settings
VECTOR_DB_PROVIDER=pgvector

# Rate Limits
RATE_LIMIT_GLOBAL_MAX=10000
RATE_LIMIT_USER_MAX=300

# Feature Flags
FEATURE_RAG_ENABLED=true
FEATURE_SYNC_ENABLED=true
FEATURE_AI_ENABLED=true
